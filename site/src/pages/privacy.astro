---
// Privacy policy page — content synced from docs/PRIVACY.md at build time
// (see package.json "build"). Canonical URL for the App Store metadata.
import { Content } from "../content/privacy.md";
const title = "Lyklaborð — persónuverndarstefna / privacy policy";
---

<!doctype html>
<html lang="is">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="index" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <style>
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.65;
        color: #1c1c1e;
        background: #fff;
      }
      @media (prefers-color-scheme: dark) {
        body { color: #e5e5ea; background: #111; }
        a { color: #7fb2ff; }
      }
      main {
        max-width: 42rem;
        margin: 0 auto;
        padding: 3rem 1.25rem 5rem;
      }
      h1 { font-size: 1.6rem; line-height: 1.3; }
      h2 { margin-top: 2.5rem; border-bottom: 1px solid rgba(128,128,128,.3); padding-bottom: .3rem; }
      h3 { margin-top: 1.8rem; }
      blockquote { margin: 1rem 0; padding: .1rem 1rem; border-left: 3px solid rgba(128,128,128,.4); opacity: .85; }
      code { font-size: .9em; }
      a.home { display: inline-block; margin-bottom: 2rem; text-decoration: none; }
    </style>
  </head>
  <body>
    <main>
      <a class="home" href="/">← lyklabord.solberg.is</a>
      <Content />
    </main>
  </body>
</html>
