---
// Shared page shell: design tokens, reset, head boilerplate, footer.
// Pages own their content styles; this owns the foundation.
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage = "/og.png" } = Astro.props;

// Absolute URLs for canonical + social cards (crawlers and chat/agent
// unfurlers require absolute image/URL values, not root-relative paths).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;

// Structured data so search engines and AI agents can read the app as a
// SoftwareApplication (name, platform, price, download link) rather than
// inferring it from prose.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Lyklaborð",
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "iOS 18",
  description,
  url: "https://lyklabord.solberg.is",
  downloadUrl: "https://apps.apple.com/app/id6792012916",
  image: ogImageURL,
  author: { "@type": "Person", name: "Jökull Sólberg" },
  inLanguage: ["is", "en"],
  isAccessibleForFree: true,
  license: "https://opensource.org/licenses/MIT",
  offers: [
    { "@type": "Offer", price: "0", priceCurrency: "USD", name: "Lyklaborð" },
    {
      "@type": "Offer",
      price: "19.99",
      priceCurrency: "USD",
      name: "Lyklaborð+",
      description: "On-device personal learning; annual subscription.",
    },
  ],
};
---

<!doctype html>
<html lang="is">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lyklaborð" />
    <meta property="og:locale" content="is_IS" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lyklaborð — íslenskt lyklaborð" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#faf9f6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1c1b1a" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style is:global>
      :root {
        --plastic: #d7d2c8;
        --bg: #faf9f6;
        --bg-raised: #f1efe9;
        --ink: #1c1b1a;
        --ink-soft: #55524d;
        --rule: #e3e0d8;
        color-scheme: light dark;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1c1b1a;
          --bg-raised: #242220;
          --ink: #e8e5e0;
          --ink-soft: #a5a19a;
          --rule: #33302c;
        }
      }
      :root[data-theme="light"] {
        --bg: #faf9f6;
        --bg-raised: #f1efe9;
        --ink: #1c1b1a;
        --ink-soft: #55524d;
        --rule: #e3e0d8;
      }
      :root[data-theme="dark"] {
        --bg: #1c1b1a;
        --bg-raised: #242220;
        --ink: #e8e5e0;
        --ink-soft: #a5a19a;
        --rule: #33302c;
      }
      * {
        margin: 0;
        box-sizing: border-box;
      }
      html {
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        font-size: 17px;
        line-height: 1.6;
        -webkit-text-size-adjust: 100%;
      }
      body {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }
      a {
        color: inherit;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.18em;
      }
      footer {
        margin-top: clamp(4rem, 10vh, 7rem);
        border-top: 1px solid var(--rule);
        padding: 1.6rem 1.5rem 2.2rem;
        text-align: center;
        font-size: 0.8rem;
        color: var(--ink-soft);
      }
      footer .footer-links {
        display: flex;
        gap: 1.2em;
        justify-content: center;
        margin-bottom: 0.7rem;
        font-size: 0.85rem;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    <footer>
      <nav class="footer-links" aria-label="Vefkort">
        <a href="/hjalp">Hjálp</a>
        <a href="/privacy">Persónuvernd</a>
        <a href="https://github.com/jokull/LyklabordApp">GitHub</a>
      </nav>
      <p>
        MIT-leyfi · BÍN © Stofnun Árna Magnússonar í íslenskum fræðum · Smíðað á
        Íslandi
      </p>
    </footer>
  </body>
</html>
